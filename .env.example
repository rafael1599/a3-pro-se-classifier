# Conexión a Supabase Postgres (modo Session Pooler recomendado para Flask síncrono).
# Formato: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Token de CourtListener (https://www.courtlistener.com/help/api/rest/).
COURTLISTENER_TOKEN=

# Cuota diaria máxima de llamadas a CourtListener (free tier = 125; dejamos margen).
DAILY_QUOTA=120

# Puerto HTTP interno del contenedor.
PORT=8000
